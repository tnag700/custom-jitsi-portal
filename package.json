{
  "scripts": {
    "frontend:install": "npm --prefix frontend-qwik install",
    "frontend:dev": "npm --prefix frontend-qwik run dev",
    "frontend:build": "npm --prefix frontend-qwik run build",
    "frontend:preview": "npm --prefix frontend-qwik run preview",
    "frontend:start": "npm --prefix frontend-qwik run start",
    "frontend:verify:ssr": "npm --prefix frontend-qwik run verify:ssr",
    "prod:up": "npm run stack:up",
    "prod:down": "npm run stack:down",
    "prod:up:monitoring": "npm run stack:up:monitoring",
    "prod:down:monitoring": "npm run stack:down:monitoring",
    "prod:config": "npm run stack:config",
    "prod:config:monitoring": "npm run stack:config:monitoring",
    "stack:up": "docker compose up --build",
    "stack:up:monitoring": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml up --build",
    "stack:down": "docker compose down",
    "stack:down:monitoring": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml down",
    "stack:config": "docker compose config",
    "stack:config:monitoring": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml config",
    "observability:drill": "pwsh -File scripts/run-observability-live-drill.ps1",
    "observability:drill:extended": "pwsh -File scripts/run-observability-live-drill.ps1 -Cycles 6 -CycleIntervalSeconds 10 -JoinSuccessRequestsPerCycle 3 -JoinFailureRequestsPerCycle 3 -RefreshPairsPerCycle 2 -PrometheusWaitSeconds 25",
    "observability:alerting:validate": "pwsh -File scripts/validate-observability-alerting.ps1",
    "observability:alerting:smoke": "pwsh -File scripts/run-observability-live-drill.ps1 -Cycles 1 -JoinSuccessRequestsPerCycle 1 -JoinFailureRequestsPerCycle 0 -RefreshPairsPerCycle 2 -PrometheusWaitSeconds 20 -WaitForAlertState cycle -AlertName JitsiAuthRefreshReuseSpike -AlertWarmupSeconds 20 -AlertPollIntervalSeconds 5 -AlertWaitTimeoutSeconds 180 -QuietWindowSeconds 135",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "openapi:check": "node scripts/check-openapi.mjs",
    "frontend:api-types:check": "node scripts/check-frontend-api-types.mjs"
  },
  "dependencies": {
    "@tanstack/svelte-query": "^6.0.18",
    "@upstash/context7-mcp": "^2.1.2"
  }
}
