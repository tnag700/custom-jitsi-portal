# Production secrets and public URLs
#
# Mode A: domain-based deployment
#   https://portal.example.com
#   https://auth.example.com
#   https://meet.example.com
#
# Mode B: static-IP deployment without DNS
#   http://203.0.113.10
#   http://203.0.113.10:8081 for Keycloak
#   https://203.0.113.10:8443 or http://203.0.113.10:8000 for Jitsi, depending on your edge setup
#
# Copy this file to .env.production or .env.production.local and replace the sample values.
SPRING_PROFILES_ACTIVE=prod

# Public application URLs
APP_FRONTEND_ORIGIN=https://portal.example.com
APP_OPENAPI_SERVER_URL=https://portal.example.com
APP_SECURITY_JWT_ISSUER=https://portal.example.com
APP_MEETINGS_TOKEN_ISSUER=https://portal.example.com
APP_MEETINGS_TOKEN_JOIN_URL_TEMPLATE=https://meet.example.com/%s#jwt=%s
APP_MEETINGS_TOKEN_AUDIENCE=jitsi-meet
APP_MEETINGS_TOKEN_ROLE_CLAIM_NAME=role
APP_MEETINGS_TOKEN_ALGORITHM=HS256

# Backend app secrets
APP_MEETINGS_TOKEN_SIGNING_SECRET=replace-with-32-plus-random-bytes
SSO_CLIENT_ID=jitsi-backend
SSO_CLIENT_SECRET=replace-with-real-client-secret

# OIDC / Keycloak public and internal endpoints
SSO_AUTHORIZATION_URI=https://auth.example.com/realms/jitsi/protocol/openid-connect/auth
SSO_TOKEN_URI=http://keycloak:8080/realms/jitsi/protocol/openid-connect/token
SSO_JWK_SET_URI=http://keycloak:8080/realms/jitsi/protocol/openid-connect/certs
SSO_USER_INFO_URI=http://keycloak:8080/realms/jitsi/protocol/openid-connect/userinfo
APP_SECURITY_SSO_EXPECTED_ISSUER=https://auth.example.com/realms/jitsi

# Database and Redis
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/jitsi
SPRING_DATASOURCE_USERNAME=jitsi
SPRING_DATASOURCE_PASSWORD=replace-with-strong-db-password
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
POSTGRES_DB=jitsi
POSTGRES_USER=jitsi
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# Keycloak bootstrap and hostname
KEYCLOAK_ADMIN=replace-with-bootstrap-admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-bootstrap-admin-password
KC_HOSTNAME=https://auth.example.com

# Jitsi JWT and public entrypoint
JWT_APP_ID=https://portal.example.com
JWT_APP_SECRET=replace-with-same-value-as-APP_MEETINGS_TOKEN_SIGNING_SECRET
JWT_ACCEPTED_ISSUERS=https://portal.example.com
JWT_ACCEPTED_AUDIENCES=jitsi-meet
PUBLIC_URL=https://meet.example.com

# Static-IP example values:
# APP_FRONTEND_ORIGIN=http://203.0.113.10
# APP_OPENAPI_SERVER_URL=http://203.0.113.10
# APP_SECURITY_JWT_ISSUER=http://203.0.113.10
# APP_MEETINGS_TOKEN_ISSUER=http://203.0.113.10
# APP_MEETINGS_TOKEN_JOIN_URL_TEMPLATE=https://203.0.113.10:8443/%s#jwt=%s
# SSO_AUTHORIZATION_URI=http://203.0.113.10:8081/realms/jitsi/protocol/openid-connect/auth
# APP_SECURITY_SSO_EXPECTED_ISSUER=http://203.0.113.10:8081/realms/jitsi
# KC_HOSTNAME=http://203.0.113.10:8081
# JWT_APP_ID=http://203.0.113.10
# JWT_ACCEPTED_ISSUERS=http://203.0.113.10
# PUBLIC_URL=https://203.0.113.10:8443

# Optional observability
APP_FEATURES_ADVANCED_MONITORING=false
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MONITORING_ENVIRONMENT=prod
MONITORING_SERVICE_NAME=jitsi-backend