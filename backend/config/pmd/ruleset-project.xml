<?xml version="1.0" encoding="UTF-8"?>
<ruleset
    name="Jitsi Backend Project Rules"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/pmd-6.0.0/ruleset_xml_schema.xsd"
>
  <description>
    Project-specific high-priority PMD checks for Jitsi backend.
    This file is intended for team-level tuning and gradual strictness increases.
  </description>

  <rule ref="category/java/bestpractices.xml/UnusedPrivateField" />
  <rule ref="category/java/bestpractices.xml/UnusedPrivateMethod" />
  <rule ref="category/java/errorprone.xml/EmptyCatchBlock" />
  <rule ref="category/java/errorprone.xml/AssignmentInOperand" />
  <rule ref="category/java/errorprone.xml/EqualsNull" />
  <rule ref="category/java/design.xml/CyclomaticComplexity">
    <priority>2</priority>
    <properties>
      <property name="methodReportLevel" value="12" />
      <property name="classReportLevel" value="120" />
    </properties>
  </rule>
  <rule ref="category/java/design.xml/NPathComplexity">
    <priority>2</priority>
    <properties>
      <property name="reportLevel" value="250" />
    </properties>
  </rule>
</ruleset>
